{
    "name": "queue-master-kiosk",
    "private": true,
    "version": "0.0.0",
    "description": "Queue Master — ticket queue management system kiosk app",
    "author": {
        "name": "Michal Ramus",
        "email": "ramus.michal21@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/michalramus/queue-master"
    },
    "homepage": "https://github.com/michalramus/queue-master",
    "type": "module",
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "npm-run-all --parallel dev:react dev:electron",
        "dev:react": "vite",
        "dev:electron": "yarn run transpile:electron && cross-env NODE_ENV=development electron . config.json",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "transpile:electron": "tsc -p src/electron/tsconfig.json",
        "dist:mac": "yarn run transpile:electron && yarn run build && electron-builder --mac --arm64",
        "dist:win": "yarn run transpile:electron && yarn run build && electron-builder --win --x64 --publish never",
        "dist:linux": "yarn run transpile:electron && yarn run build && electron-builder --linux --x64 --publish never",
        "pre-push": "tsc -p src/electron/tsconfig.json --noEmit && tsc -b --noEmit"
    },
    "dependencies": {
        "@tailwindcss/typography": "^0.5.20",
        "@tanstack/react-query": "^5.101.2",
        "axios": "^1.18.1",
        "i18next": "^26.3.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-error-boundary": "^6.1.2",
        "react-i18next": "^17.0.8",
        "shared-components": "1.0.0",
        "shared-utils": "1.0.0",
        "tailwindcss": "^4.3.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/postcss": "^4.3.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "cross-env": "^10.1.0",
        "electron": "42.5.0",
        "electron-builder": "26.15.6",
        "eslint": "^10.6.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "flag-icons": "^7.5.0",
        "globals": "^17.7.0",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.16",
        "prettier": "^3.9.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0"
    },
    "lint-staged": {
        "**/*.{ts,tsx}": [
            "eslint --cache --fix --max-warnings=0",
            "prettier --write"
        ]
    }
}
